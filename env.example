# YouTube API Configuration
YT_CLIENT_SECRET='{"type": "service_account", "project_id": "..."}'

# Facebook API Configuration
FB_ACCESS_TOKEN=your_facebook_access_token
FB_PAGE_ID=your_facebook_page_id

# Image Generation APIs
GEMINI_API_KEY=your_gemini_api_key
HF_API_KEY=your_huggingface_api_key
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
MODELSLAB_API_KEY=your_modelslab_api_key
REPLICATE_API_TOKEN=your_replicate_api_token
PEXELS_API_KEY=your_pexels_api_key
PIXABAY_API_KEY=your_pixabay_api_key
# ^ IMPORTANT: these 2 are now REQUIRED, not optional. Image fallback chain
# is just ToolScreenRecord -> Pexels -> Pixabay (all other layers removed).
# If a scene has no tool_url AND both keys are missing/rate-limited, that
# scene gets no image and the video build will fail.

# LLM Configuration
GROQ_API_KEY=your_groq_api_key

# Video Topic
VIDEO_TOPIC=3 Scary True Stories That Happened at 3 AM

# Text-to-Speech Engine
# kokoro     = original fixed built-in voices (no cloning, lighter/faster)
# chatterbox = zero-shot voice cloning (MIT license, free for commercial use)
TTS_ENGINE=kokoro

# Only needed when TTS_ENGINE=chatterbox
# Path to a 5-15 second clean WAV/MP3 clip of the voice you want to clone.
# You must have permission/consent to use this voice.
VOICE_REFERENCE_PATH=assets/my_voice_sample.wav

# Language for Chatterbox's multilingual model. "en" = original English-only
# model (fastest). Any other value loads ChatterboxMultilingualTTS.
# Urdu has no official code in Chatterbox - "hi" (Hindi) is the closest
# supported language, used as an experiment. TEST with test_urdu_voice.py
# before trusting this for real videos.
CHATTERBOX_LANGUAGE=hi
