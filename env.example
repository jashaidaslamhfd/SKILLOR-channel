# LLM
GROQ_API_KEY=

# Trend research — Google Trends RSS works without a key. YouTube and Reddit
# use official APIs and are optional; they improve reliability over scraping.
TREND_REGION=FR
YOUTUBE_REGION_CODE=FR
# 500-episode micro-niche launch. Do not force unrelated daily news trends.
CONTENT_SERIES=body_glitches_fr
TOPIC_STRATEGY=body_glitch_series_fr
REQUIRE_DAILY_TREND=false
CHANNEL_LANGUAGE=fr-FR
CHANNEL_COUNTRY=FR
KOKORO_LANG_CODE=f
KOKORO_VOICE=ff_siwis
TTS_ENGINE=kokoro
REQUIRE_CLONED_VOICE=false
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# YouTube OAuth user credentials (service accounts cannot upload to a normal channel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REFRESH_TOKEN=
YT_MADE_FOR_KIDS=false
# Safety first: review every generated science video before making it public.
# When YT_PRIVACY_STATUS=public and YT_SCHEDULE_PUBLISH=true, the video uploads
# private and YouTube auto-publishes it at the next Paris peak (08/13/19).
YT_PRIVACY_STATUS=private
YT_SCHEDULE_PUBLISH=true
# Honest YouTube altered/synthetic content disclosure (AI voice + AI visuals).
YT_DECLARE_SYNTHETIC_MEDIA=true
# Auto-add each Short to its SEO-suggested series playlist.
YT_PLAYLIST_ENABLED=true

# Optional image providers
HF_API_KEY=
GEMINI_API_KEY=
DEEPAI_API_KEY=
MODELSLAB_API_KEY=
REPLICATE_API_TOKEN=
PEXELS_API_KEY=
PIXABAY_API_KEY=
AI_HORDE_API_KEY=

# Optional Facebook. Disabled by default while YouTube videos are privately
# reviewed; Facebook Reels otherwise publish immediately.
FB_ACCESS_TOKEN=
FB_PAGE_ID=
FB_UPLOAD_ENABLED=false

# Body Glitch series policy: one complete 40–55 second, eight-scene Short.
TARGET_MIN_SECONDS=40
TARGET_MAX_SECONDS=55
MIN_HOOK_SCORE=70
MAX_HOOK_SECONDS=5.0
QUALITY_APPROVAL_THRESHOLD=60
# Natural YouTube clone profile. Use a clean 30–60 second single-speaker
# WAV at VOICE_REFERENCE_PATH for the closest identity match.
CHATTERBOX_TEMPO=0.96
CHATTERBOX_EXAGGERATION=0.35
CHATTERBOX_CFG_WEIGHT=0.70
CHATTERBOX_TEMPERATURE=0.60
# Uses an actual track from assets/music. Leave empty to rotate among all
# supported files there, or set an exact filename to lock one track.
MUSIC_TRACK=
MUSIC_VOLUME=0.07
ENABLE_SCREENSHOT_FALLBACK=false
VOICE_REFERENCE_PATH=assets/voice_reference.wav
# Durable repository-backed state (committed by GitHub Actions).
VIDEO_HISTORY_PATH=data/video_history.json
UPLOAD_STATE_PATH=data/upload_state.json
VIDEO_TOPIC=
