# ===== Groq (script generation) =====
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Stock footage =====
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

# ===== YouTube Upload (Google Cloud OAuth Client - Desktop App type) =====
YOUTUBE_CLIENT_SECRET_FILE=config/client_secret.json
YOUTUBE_TOKEN_FILE=config/youtube_token.json

# ===== TikTok (optional, Selenium-based, use with caution) =====
TIKTOK_SESSION_ID=your_tiktok_sessionid_cookie

# ===== TTS Voice =====
TTS_VOICE=ur-PK-AsadNeural
